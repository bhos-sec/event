rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Email verification codes - Cloud Functions only (no client access)
    match /email_verification_codes/{email} {
      allow read, write: if false;
    }
    // User profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/history/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // BHOS Event Manager - API routes use Admin SDK (bypasses rules)
    // Client access: authenticated users can read/write events they created
    match /events/{eventId} {
      allow read, write: if request.auth != null;
    }
    match /participants/{participantId} {
      allow read, write: if request.auth != null;
    }
    match /checkIns/{checkInId} {
      allow read, write: if request.auth != null;
    }
    match /waitlist/{entryId} {
      allow read, write: if request.auth != null;
    }
    match /eventFeedback/{feedbackId} {
      allow read, write: if request.auth != null;
    }
  }
}
