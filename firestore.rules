rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Email verification codes - Cloud Functions only (no client access)
    match /email_verification_codes/{email} {
      allow read, write: if false;
    }
    // User profile (firstName, lastName, etc.)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Users can only read/write their own history
    match /users/{userId}/history/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
